{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/schemas/x07.mcp.sarif.schema.json",
  "title": "x07.mcp.sarif@0.1.0",
  "type": "object",
  "additionalProperties": true,
  "required": ["version", "runs"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "const": "2.1.0" },
    "runs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": ["tool"],
        "properties": {
          "tool": {
            "type": "object",
            "additionalProperties": true,
            "required": ["driver"],
            "properties": {
              "driver": {
                "type": "object",
                "additionalProperties": true,
                "required": ["name"],
                "properties": { "name": { "type": "string", "minLength": 1 } }
              }
            }
          },
          "results": { "type": "array" }
        }
      }
    }
  }
}

