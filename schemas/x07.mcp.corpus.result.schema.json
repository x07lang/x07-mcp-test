{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/schemas/x07.mcp.corpus.result.schema.json",
  "title": "x07.mcp.corpus.result@0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "tool",
    "tool_version",
    "target",
    "ok",
    "errors",
    "warnings",
    "details"
  ],
  "properties": {
    "schema_version": { "const": "x07.mcp.corpus.result@0.1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "tool": { "type": "string", "minLength": 1 },
    "tool_version": { "type": "string", "minLength": 1 },
    "target": { "$ref": "#/$defs/target" },
    "ok": { "type": "boolean" },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/msg" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/msg" } },
    "details": { "$ref": "#/$defs/corpus_result_details" }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "transport", "ref", "meta"],
      "properties": {
        "kind": { "enum": ["mcp_server", "file"] },
        "transport": { "enum": ["streamable_http", "stdio", "file"] },
        "ref": { "type": "string", "minLength": 1 },
        "meta": { "type": "object", "additionalProperties": true }
      }
    },
    "msg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "message"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "version"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "registry_id": { "type": "string", "minLength": 1 }
      }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["out_dir", "summary_json", "junit_xml", "html", "sarif"],
      "properties": {
        "out_dir": { "type": "string", "minLength": 1 },
        "summary_json": { "type": "string", "minLength": 1 },
        "junit_xml": { "type": "string", "minLength": 1 },
        "html": { "type": "string", "minLength": 1 },
        "sarif": { "type": "string", "minLength": 1 }
      }
    },
    "corpus_result_details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "server_id", "status", "source", "outputs"],
      "properties": {
        "report_id": { "type": "string", "minLength": 1 },
        "server_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["stub", "complete"] },
        "source": { "$ref": "#/$defs/source" },
        "outputs": { "$ref": "#/$defs/outputs" }
      }
    }
  }
}

