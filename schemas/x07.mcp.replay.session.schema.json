{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/schemas/x07.mcp.replay.session.schema.json",
  "title": "x07.mcp.replay.session@0.2.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "tool",
    "tool_version",
    "target",
    "ok",
    "errors",
    "warnings",
    "details"
  ],
  "properties": {
    "schema_version": { "const": "x07.mcp.replay.session@0.2.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "tool": { "type": "string", "minLength": 1 },
    "tool_version": { "type": "string", "minLength": 1 },
    "target": { "$ref": "#/$defs/target" },
    "ok": { "type": "boolean" },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/msg" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/msg" } },
    "details": { "$ref": "#/$defs/replay_session_details" }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "transport", "ref", "meta"],
      "properties": {
        "kind": { "enum": ["mcp_server", "file"] },
        "transport": { "enum": ["streamable_http", "stdio", "file"] },
        "ref": { "type": "string", "minLength": 1 },
        "meta": { "type": "object", "additionalProperties": true }
      }
    },
    "msg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "message"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "replay_session_details": {
      "type": "object",
      "additionalProperties": true,
      "required": ["scenario", "http_session"],
      "properties": {
        "scenario": { "type": "string", "minLength": 1 },
        "http_session": { "$ref": "#/$defs/http_session" }
      }
    },
    "http_session": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "id", "profile", "project_files", "base_url", "mcp_path", "steps"],
      "properties": {
        "schema_version": { "const": "x07.mcp.rr.http_session@0.1.0" },
        "id": { "type": "string", "minLength": 1 },
        "profile": { "type": "string", "minLength": 1 },
        "project_files": { "type": "object", "additionalProperties": true },
        "base_url": { "type": "string", "minLength": 1 },
        "mcp_path": { "type": "string", "minLength": 1 },
        "steps": { "type": "array", "items": { "$ref": "#/$defs/http_step" } }
      }
    },
    "http_step": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "req", "res"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "req": { "$ref": "#/$defs/http_req" },
        "res": { "$ref": "#/$defs/http_res" }
      }
    },
    "http_req": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "path", "headers"],
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } },
        "body_json": {}
      }
    },
    "http_res": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "headers"],
      "properties": {
        "status": { "type": "integer" },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } },
        "body_json": {},
        "body_empty": { "type": "boolean" }
      },
      "anyOf": [{ "required": ["body_json"] }, { "required": ["body_empty"] }]
    }
  }
}
