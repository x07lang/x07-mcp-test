{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/schemas/x07.mcp.trust.summary.schema.json",
  "title": "x07.mcp.trust.summary@0.2.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "tool",
    "tool_version",
    "target",
    "ok",
    "errors",
    "warnings"
  ],
  "properties": {
    "schema_version": { "const": "x07.mcp.trust.summary@0.2.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "tool": { "type": "string", "minLength": 1 },
    "tool_version": { "type": "string", "minLength": 1 },
    "target": { "$ref": "#/$defs/target" },
    "ok": { "type": "boolean" },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/msg" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/msg" } },
    "details": { "type": "object", "additionalProperties": true }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "transport", "ref", "meta"],
      "properties": {
        "kind": { "enum": ["mcp_server", "file"] },
        "transport": { "enum": ["streamable_http", "stdio", "file"] },
        "ref": { "type": "string", "minLength": 1 },
        "meta": { "type": "object", "additionalProperties": true }
      }
    },
    "msg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "message"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
