{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/schemas/x07.mcp.corpus.summary.schema.json",
  "title": "x07.mcp.corpus.summary@0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "tool",
    "tool_version",
    "target",
    "ok",
    "errors",
    "warnings",
    "details"
  ],
  "properties": {
    "schema_version": { "const": "x07.mcp.corpus.summary@0.1.0" },
    "generated_at": { "type": "string", "format": "date-time" },
    "tool": { "type": "string", "minLength": 1 },
    "tool_version": { "type": "string", "minLength": 1 },
    "target": { "$ref": "#/$defs/target" },
    "ok": { "type": "boolean" },
    "errors": { "type": "array", "items": { "$ref": "#/$defs/msg" } },
    "warnings": { "type": "array", "items": { "$ref": "#/$defs/msg" } },
    "details": { "$ref": "#/$defs/corpus_summary_details" }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "transport", "ref", "meta"],
      "properties": {
        "kind": { "enum": ["mcp_server", "file"] },
        "transport": { "enum": ["streamable_http", "stdio", "file"] },
        "ref": { "type": "string", "minLength": 1 },
        "meta": { "type": "object", "additionalProperties": true }
      }
    },
    "msg": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "message"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "result_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["server_id", "status", "ok", "result_path", "out_dir"],
      "properties": {
        "server_id": { "type": "string", "minLength": 1 },
        "status": { "enum": ["stub", "complete"] },
        "ok": { "type": "boolean" },
        "result_path": { "type": "string", "minLength": 1 },
        "out_dir": { "type": "string", "minLength": 1 }
      }
    },
    "counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total", "ok", "failed", "stub"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "ok": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 },
        "stub": { "type": "integer", "minimum": 0 }
      }
    },
    "corpus_summary_details": {
      "type": "object",
      "additionalProperties": false,
      "required": ["report_id", "results", "counts"],
      "properties": {
        "report_id": { "type": "string", "minLength": 1 },
        "results": { "type": "array", "items": { "$ref": "#/$defs/result_ref" } },
        "counts": { "$ref": "#/$defs/counts" }
      }
    }
  }
}

