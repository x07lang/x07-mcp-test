{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://x07.io/schemas/x07.mcp.report.manifest.schema.json",
  "title": "x07.mcp.report.manifest@0.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "report_id", "targets"],
  "properties": {
    "schema_version": { "const": "x07.mcp.report.manifest@0.1.0" },
    "report_id": { "type": "string", "minLength": 1 },
    "targets": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/target_spec" } },
    "notes": { "type": "string" }
  },
  "$defs": {
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "transport", "ref", "meta"],
      "properties": {
        "kind": { "enum": ["mcp_server", "file"] },
        "transport": { "enum": ["streamable_http", "stdio", "file"] },
        "ref": { "type": "string", "minLength": 1 },
        "meta": { "type": "object", "additionalProperties": true }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repo", "version"],
      "properties": {
        "repo": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "commit": { "type": "string", "minLength": 1 },
        "registry_id": { "type": "string", "minLength": 1 }
      }
    },
    "assumptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["auth_mode"],
      "properties": {
        "auth_mode": { "enum": ["none", "bearer", "oauth", "unknown"] },
        "notes": { "type": "string" }
      }
    },
    "exclusions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["skip_scenarios"],
      "properties": {
        "skip_scenarios": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "notes": { "type": "string" }
      }
    },
    "target_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target", "assumptions", "exclusions"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "source": { "$ref": "#/$defs/source" },
        "target": { "$ref": "#/$defs/target" },
        "assumptions": { "$ref": "#/$defs/assumptions" },
        "exclusions": { "$ref": "#/$defs/exclusions" }
      }
    }
  }
}

